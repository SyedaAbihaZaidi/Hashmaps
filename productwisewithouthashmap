import java.io.File;
import java.util.Scanner;

public class productwisewithouthashmap_1 {

    public static void main(String[] args) {

        try {

            // Creating File object
            File file = new File("E:\\Abiha\\SalesEVESession.txt");

            // Scanner object to read file
            Scanner sc = new Scanner(file);

            // Skip first line (header line)
            sc.nextLine();

            // Array to store product names
            String[] products = new String[1000];

            // Array to store product-wise sums
            double[] sums = new double[1000];

            // Variable to count unique products
            int count = 0;

            // Read file line by line
            while (sc.hasNextLine()) {

                // Read one line from file
                String line = sc.nextLine();

                // Skip empty lines
                if (line.trim().length() == 0)
                    continue;

                // Split line using tab delimiter
                String[] data = line.split("\t");

                // Extract product name
                String product = data[1];

                // Extract unit price
                double unitPrice = Double.parseDouble(data[2]);

                // Extract quantity
                int qty = Integer.parseInt(data[3]);

                // Calculate total amount
                double total = unitPrice * qty;

                // Variable to check if product already exists
                boolean found = false;

                // Search product in array
                for (int i = 0; i < count; i++) {

                    // If product already exists
                    if (products[i].equals(product)) {

                        // Add amount to existing sum
                        sums[i] += total;

                        found = true;
                        break;
                    }
                }

                // If product does not exist
                if (!found) {

                    // Store product name
                    products[count] = product;

                    // Store total amount
                    sums[count] = total;

                    // Increase count
                    count++;
                }
            }

            // Display heading
            System.out.println("Product Wise Sum");

            // Display all products with their sums
            for (int i = 0; i < count; i++) {

                System.out.println(products[i] + " = " + sums[i]);
            }

            // Close scanner
            sc.close();

        } catch (Exception e) {

            // Display error message
            System.out.println("Error : " + e.getMessage());
        }
    }
}
