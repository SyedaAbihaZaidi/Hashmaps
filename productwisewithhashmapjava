import java.util.Scanner;
import java.io.File;
import java.util.HashMap;
import java.util.Map;

public class productwisewithhashmap_1 {

    public static void main(String[] args) {

        // Creating File object to access the sales file
        File f1 = new File("E:\\inayah\\SalesEVESession.txt");

        // Scanner object for reading file data
        Scanner inp;

        // Variable to store each line from file
        String dl;

        // HashMap to store:
        // Key   = Product Name
        // Value = Total Sales Amount
        HashMap<String, Double> hm = new HashMap<>();

        try {

            // Opening file using Scanner
            inp = new Scanner(f1);

            // Reading first line (header line)
            dl = inp.nextLine();

            // Variables for quantity, amount and unit price
            double qty, amt, uPrice;

            // Loop to read all lines from file
            while (inp.hasNextLine()) {

                // Read next line
                dl = inp.nextLine();

                // Skip empty lines
                if (dl.trim().length() == 0)
                    continue;

                // Split line using tab delimiter
                String[] parts = dl.split("\t");

                // Extract product name
                String productName = parts[1];

                // Extract quantity
                qty = Double.parseDouble(parts[3]);

                // Extract unit price
                uPrice = Double.parseDouble(parts[2]);

                // Calculate total amount
                amt = qty * uPrice;

                // Check if product already exists in HashMap
                if (hm.containsKey(productName)) {

                    // Add previous amount to current amount
                    amt += hm.get(productName);
                }

                // Store updated amount in HashMap
                hm.put(productName, amt);
            }

        } catch (Exception e) {

            // Display error message if exception occurs
            System.out.println("Error : " + e.getMessage());
        }

        // Display heading
        System.out.println("Product Wise Sum");

        // Traverse HashMap and display product-wise totals
        for (Map.Entry<String, Double> me : hm.entrySet()) {

            System.out.println(me.getKey() + " --- " + me.getValue());
        }
    }
}
